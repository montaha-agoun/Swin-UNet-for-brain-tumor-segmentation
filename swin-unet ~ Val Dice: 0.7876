   0.7358   0.6744   0.7105  0.6402  0.6747\n  [ckpt] Checkpoint saved → ./swinunet_checkpoint.pth\n    26   0.6911   0.7342   0.6306   0.4980  0.5968  0.4613\n  [ckpt] Checkpoint saved → ./swinunet_checkpoint.pth\n    27   0.6875   0.7350   0.6669   0.7183  0.6327  0.6827\n  [ckpt] Checkpoint saved → ./swinunet_checkpoint.pth\n    28   0.6889   0.7354   0.6693   0.6394  0.6353  0.6035\n  [ckpt] Checkpoint saved → ./swinunet_checkpoint.pth\n    29   0.6876   0.7333   0.6976   0.6427  0.6637  0.6070\n  [ckpt] Checkpoint saved → ./swinunet_checkpoint.pth\n    30   0.6875   0.7324   0.6840   0.7174  0.6504  0.6825\n  [ckpt] Checkpoint saved → ./swinunet_checkpoint.pth\n    31   0.6869   0.7337   0.7002   0.7061  0.6666  0.6709\n  [ckpt] Checkpoint saved → ./swinunet_checkpoint.pth\n    32   0.6863   0.7309   0.6850   0.6203  0.6511  0.5847\n  [ckpt] Checkpoint saved → ./swinunet_checkpoint.pth\n    33   0.6874   0.7312   0.6486   0.5720  0.6150  0.5364\n  [ckpt] Checkpoint saved → ./swinunet_checkpoint.pth\n    34   0.6860   0.7323   0.6776   0.7347  0.6444  0.6997\n  [ckpt] Checkpoint saved → ./swinunet_checkpoint.pth\n    35   0.6848   0.7302   0.7181   0.5944  0.6845  0.5589\n  [ckpt] Checkpoint saved → ./swinunet_checkpoint.pth\n    36   0.6853   0.7286   0.6858   0.6119  0.6527  0.5765\n  [ckpt] Checkpoint saved → ./swinunet_checkpoint.pth\n    37   0.6833   0.7293   0.6792   0.6213  0.6460  0.5858\n  [ckpt] Checkpoint saved → ./swinunet_checkpoint.pth\n    38   0.6845   0.7293   0.6779   0.6849  0.6447  0.6498\n  [ckpt] Checkpoint saved → ./swinunet_checkpoint.pth\n    39   0.6840   0.7297   0.7105   0.6814  0.6771  0.6464\n  [ckpt] Checkpoint saved → ./swinunet_checkpoint.pth\n    40   0.6839   0.7297   0.7056   0.6459  0.6725  0.6105\n\n Training complete — Best Val Dice: 0.7876\n","output_type":"stream"}],"execution_count":32},{"cell_type":"code","source":"# ── Cell 11: Learning curves ──────────────────────────────────────────────────\nactual_num_epochs = len(history['tl'])\nepochs = range(1, actual_num_epochs + 1)\n\nfig, axes = plt.subplots(1, 3, figsize=(16, 4))\nfig.suptitle('Training History', fontsize=14, fontweight='bold')\n\ntitles   = ['Loss (DiceBCE)', 'Dice Score', 'IoU Score']\nt_series = [history['tl'], history['td'], history['ti']]\nv_series = [history['vl'], history['vd'], history['vi']]\n\nfor ax, title, tr, vl in zip(axes, titles, t_series, v_series):\n    ax.plot(epochs, tr, label='Train', color='#3498db', linewidth=2)\n    ax.plot(epochs, vl, label='Val',   color='#e74c3c', linewidth=2)\n    ax.set_title(title, fontweight='bold')\n    ax.set_xlabel('Epoch')\n    ax.legend()\n    ax.grid(True, alpha=0.3)\n    ax.spines['top'].set_visible(False)\n    ax.spines['right'].set_visible(False)\n\nplt.tight_layout()\nplt.savefig('./training_curves.png', dpi=150, bbox_inches='tight')\nplt.show()\nprint('Saved: ./training_curves.png')","metadata":{"id":"KMNB1JZ0_06C","trusted":true,"execution":{"iopub.status.busy":"2026-06-24T08:52:39.564092Z","iopub.execute_input":"2026-06-24T08:52:39.564932Z","iopub.status.idle":"2026-06-24T08:52:40.367014Z","shell.execute_reply.started":"2026-06-24T08:52:39.564895Z","shell.execute_reply":"2026-06-24T08:52:40.366364Z"}},"outputs":[{"output_type":"display_data","data":{"text/plain":"<Figure size 1600x400 with 3 Axes>","image/png":"\n"},"metadata":{}},{"name":"stdout","text":"Saved: ./training_curves.png\n","output_type":"stream"}],"execution_count":33},{"cell_type":"code","source":"# ── Cell 12: Test set evaluation ──────────────────────────────────────────────\nmodel.load_state_dict(torch.load(CFG.best_model_path, map_location=CFG.device))\nts_loss, ts_dice, ts_iou = val_epoch(model, test_loader, criterion, CFG.device)\n\nprint('=' * 40)\nprint(f'  TEST RESULTS (best checkpoint)')\nprint('=' * 40)\nprint(f'  Loss   : {ts_loss:.4f}')\nprint(f'  Dice   : {ts_dice:.4f}')\nprint(f'  IoU    : {ts_iou:.4f}')\nprint('=' * 40)","metadata":{"id":"EMAKYlKk_06C","trusted":true,"execution":{"iopub.status.busy":"2026-06-24T08:52:45.775776Z","iopub.execute_input":"2026-06-24T08:52:45.776589Z","iopub.status.idle":"2026-06-24T08:52:51.121220Z","shell.execute_reply.started":"2026-06-24T08:52:45.776558Z","shell.execute_reply":"2026-06-24T08:52:51.120569Z"}},"outputs":[{"name":"stdout","text":"========================================\n  TEST RESULTS (best checkpoint)\n========================================\n  Loss   : 0.8118\n  Dice   : 0.8241\n  IoU    : 0.7967\n========================================\n","output_type":"stream"}],"execution_count":34},{"cell_type":"code","source":"# ── Cell 13: Qualitative predictions ─────────────────────────────────────────\n@torch.no_grad()\ndef predict_single(model, img_path, device=CFG.device, size=CFG.img_size, thr=0.40):\n    model.eval()\n    img   = Image.open(img_path).convert('RGB')\n    orig  = np.array(img)\n    inp   = TF.to_tensor(img.resize((size,size), Image.BILINEAR)).unsqueeze(0).to(device)\n    prob  = torch.sigmoid(model(inp)).squeeze().cpu().numpy()\n    mask  = (prob > thr).astype(np.uint8)\n    mask  = np.array(Image.fromarray(mask*255).resize(orig.shape[1::-1], Image.NEAREST))\n    return orig, mask, prob\n\n\n# Sample from positive test slices only — more interesting to visualise\npos_test = [(i,m) for i,m in test_pairs if np.array(Image.open(m)).max()>0]\nn_show   = min(8, len(pos_test))\nsamples  = random.sample(pos_test, n_show)\n\nfig, axes = plt.subplots(n_show, 4, figsize=(14, n_show*3.2))\nfig.suptitle('Predictions on Test Set   |   MRI · Ground Truth · Prediction · Overlay',\n             fontsize=13, fontweight='bold', y=1.01)\n\ncol_titles = ['MRI', 'Ground Truth', 'Prediction', 'Overlay (red=pred)']\nfor col, t in enumerate(col_titles):\n    axes[0,col].set_title(t, fontweight='bold', fontsize=10)\n\nfor row, (ip, mp) in enumerate(samples):\n    orig, pred, prob = predict_single(model, ip)\n    gt = np.array(Image.open(mp).convert('L'))\n\n    # Overlay: grey base + red predicted pixels\n    grey    = np.stack([orig.mean(-1)]*3, axis=-1).astype(np.uint8)\n    overlay = grey.copy()\n    overlay[pred>127] = [220, 50, 50]\n    # Green for ground truth in overlay too\n    overlay[(gt>127) & (pred<=127)] = [50, 200, 50]   # fn = green\n\n    axes[row,0].imshow(orig)\n    axes[row,1].imshow(gt,      cmap='hot', vmin=0, vmax=255)\n    axes[row,2].imshow(pred,    cmap='hot', vmin=0, vmax=255)\n    axes[row,3].imshow(overlay)\n    for ax in axes[row]: ax.axis('off')\n\n# Legend\nred_patch   = mpatches.Patch(color='#dc3232', label='Predicted tumour')\ngreen_patch = mpatches.Patch(color='#32c832', label='Missed (false negative)')\nfig.legend(handles=[red_patch, green_patch], loc='lower center',\n           ncol=2, fontsize=10, bbox_to_anchor=(0.5, -0.01))\n\nplt.tight_layout()\nplt.savefig('./predictions.png', dpi=150, bbox_inches='tight')\nplt.show()\nprint('Saved: ./predictions.png')","metadata":{"id":"6-3QZ3rG_06C","trusted":true,"execution":{"iopub.status.busy":"2026-06-24T08:54:58.030861Z","iopub.execute_input":"2026-06-24T08:54:58.031634Z","iopub.status.idle":"2026-06-24T08:55:02.312170Z","shell.execute_reply.started":"2026-06-24T08:54:58.031605Z","shell.execute_reply":"2026-06-24T08:55:02.311138Z"}},"outputs":[{"output_type":"display_data","data":{"text/plain":"<Figure size 1400x2560 with 32 Axes>","image/png":"\n"},"metadata":{}},{"name":"stdout","text":"Saved: ./predictions.png\n","output_type":"stream"}],"execution_count":39},{"cell_type":"code","source":"# ── Cell 14: Probability heatmap ──────────────────────────────────────────────\nsample_ip, sample_mp = random.choice(pos_test)\norig, pred, prob = predict_single(model, sample_ip)\ngt = np.array(Image.open(sample_mp).convert('L'))\n\nfig, axes = plt.subplots(1, 4, figsize=(16, 4))\nfig.suptitle('Deep-dive: Probability Heatmap', fontweight='bold')\n\naxes[0].imshow(orig);                                 axes[0].set_title('MRI')\naxes[1].imshow(gt,   cmap='hot', vmin=0,vmax=255);   axes[1].set_title('Ground Truth')\nim = axes[2].imshow(prob, cmap='jet', vmin=0,vmax=1)\nplt.colorbar(im, ax=axes[2]); axes[2].set_title('Probability Map')\naxes[3].imshow(pred, cmap='hot', vmin=0,vmax=255);   axes[3].set_title('Binary Prediction (thr=0.40)')\nfor ax in axes: ax.axis('off')\n\nplt.tight_layout();\nplt.savefig('./ProbaHetmap.png', dpi=150, bbox_inches='tight')\nplt.show()\nprint('Saved: ./ProbaHetmap.png')","metadata":{"id":"2xoJnuQa_06C","trusted":true,"execution":{"iopub.status.busy":"2026-06-24T08:55:26.388162Z","iopub.execute_input":"2026-06-24T08:55:26.389010Z","iopub.status.idle":"2026-06-24T08:55:27.215920Z","shell.execute_reply.started":"2026-06-24T08:55:26.388977Z","shell.execute_reply":"2026-06-24T08:55:27.215196Z"}},"outputs":[{"output_type":"display_data","data":{"text/plain":"<Figure size 1600x400 with 5 Axes>","image/png":"\n"},"metadata":{}},{"name":"stdout","text":"Saved: ./ProbaHetmap.png\n","output_type":"stream"}],"execution_count":42},{"cell_type":"code","source":"from IPython.display import FileLink\n\nFileLink('best_swinunet.pth')","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-06-24T08:58:10.480680Z","iopub.execute_input":"2026-06-24T08:58:10.480972Z","iopub.status.idle":"2026-06-24T08:58:10.489122Z","shell.execute_reply.started":"2026-06-24T08:58:10.480948Z","shell.execute_reply":"2026-06-24T08:58:10.488029Z"},"id":"qTUiIEGEaXl3"},"outputs":[{"execution_count":43,"output_type":"execute_result","data":{"text/plain":"/kaggle/working/best_swinunet.pth","text/html":"<a href='best_swinunet.pth' target='_blank'>best_swinunet.pth</a><br>"},"metadata":{}}],"execution_count":43},{"cell_type":"code","source":"from IPython.display import FileLink\nFileLink('swinunet_checkpoint.pth')\n","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-06-24T08:58:57.737298Z","iopub.execute_input":"2026-06-24T08:58:57.738065Z","iopub.status.idle":"2026-06-24T08:58:57.743246Z","shell.execute_reply.started":"2026-06-24T08:58:57.738034