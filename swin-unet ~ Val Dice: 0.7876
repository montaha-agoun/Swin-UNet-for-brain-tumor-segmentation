{"metadata":{"kernelspec":{"name":"python3","display_name":"Python 3","language":"python"},"language_info":{"name":"python","version":"3.12.13","mimetype":"text/x-python","codemirror_mode":{"name":"ipython","version":3},"pygments_lexer":"ipython3","nbconvert_exporter":"python","file_extension":".py"},"colab":{"provenance":[]},"kaggle":{"accelerator":"nvidiaTeslaT4","dataSources":[{"sourceType":"datasetVersion","sourceId":407317,"datasetId":181273,"databundleVersionId":422498}],"isInternetEnabled":true,"language":"python","sourceType":"notebook","isGpuEnabled":true}},"nbformat_minor":4,"nbformat":4,"cells":[{"cell_type":"markdown","source":"# 🧠 Swin-UNet — Brain MRI Tumor Segmentation\n**Dataset:** [LGG MRI Segmentation](https://www.kaggle.com/datasets/mateuszbuda/lgg-mri-segmentation)  \n**Task:** Binary segmentation of low-grade glioma (LGG) tumors from FLAIR MRI scans  \n**Architecture:** Swin-UNet — pure Transformer (Cao et al. 2021, arXiv:2105.05537)  \n**Key property:** ZERO convolutional layers — encoder, decoder, and head are all Transformers\n\n---\n### Pipeline\n1. Install & import\n2. Explore & visualise raw data\n3. Dataset class + augmentations\n4. **Swin-UNet architecture** with deep supervision\n5. Loss, metrics, training loop with checkpointing\n6. Train with live progress\n7. Plot learning curves\n8. Visualise predictions vs ground truth\n","metadata":{"id":"Gji4foQA_058"}},{"cell_type":"code","source":"# ── Cell 1: Install dependencies ──────────────────────────────────────────────\nimport importlib, subprocess, sys\n\nfor pkg in ['torch','torchvision','numpy','PIL','sklearn','matplotlib','tqdm']:\n    try: importlib.import_module(pkg)\n    except: subprocess.check_call([sys.executable,'-m','pip','install','-q',pkg])\n\nsubprocess.check_call([sys.executable,'-m','pip','install','-q','timm','einops'])\nprint(' All packages ready')\n","metadata":{"id":"S4rUMx76_059","trusted":true,"execution":{"iopub.status.busy":"2026-06-24T07:03:33.326084Z","iopub.execute_input":"2026-06-24T07:03:33.326504Z","iopub.status.idle":"2026-06-24T07:03:49.070014Z","shell.execute_reply.started":"2026-06-24T07:03:33.326480Z","shell.execute_reply":"2026-06-24T07:03:49.069098Z"}},"outputs":[{"name":"stdout","text":"   ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━ 12.2/12.2 MB 93.6 MB/s eta 0:00:00\n All packages ready\n","output_type":"stream"},{"name":"stderr","text":"ERROR: pip's dependency resolver does not currently take into account all the packages that are installed. This behaviour is the source of the following dependency conflicts.\ndask-cuda 26.2.0 requires cuda-core==0.3.*, but you have cuda-core 1.0.1 which is incompatible.\ndask-cuda 26.2.0 requires numba-cuda<0.23.0,>=0.22.1, but you have numba-cuda 0.30.2 which is incompatible.\ndistributed-ucxx-cu12 0.48.0 requires numba-cuda[cu12]<0.23.0,>=0.22.1, but you have numba-cuda 0.30.2 which is incompatible.\ncuml-cu12 26.2.0 requires numba<0.62.0,>=0.60.0, but you have numba 0.65.1 which is incompatible.\ncuml-cu12 26.2.0 requires numba-cuda[cu12]<0.23.0,>=0.22.1, but you have numba-cuda 0.30.2 which is incompatible.\nucxx-cu12 0.48.0 requires numba-cuda[cu12]<0.23.0,>=0.22.1, but you have numba-cuda 0.30.2 which is incompatible.\ncudf-cu12 26.2.1 requires numba<0.62.0,>=0.60.0, but you have numba 0.65.1 which is incompatible.\ncudf-cu12 26.2.1 requires numba-cuda[cu12]<0.23.0,>=0.22.2, but you have numba-cuda 0.30.2 which is incompatible.\n","output_type":"stream"}],"execution_count":1},{"cell_type":"code","source":"# ── Cell 3: Imports & config ─────────────────────────────────────────────\nimport os, glob, random, math\nimport numpy as np\nimport matplotlib.pyplot as plt\nimport matplotlib.patches as mpatches\nfrom PIL import Image\nfrom tqdm.notebook import tqdm\nfrom sklearn.model_selection import train_test_split\n\nimport torch\nimport torch.nn as nn\nimport torch.nn.functional as F\nimport torch.optim as optim\nfrom torch.utils.data import Dataset, DataLoader\nfrom torch.utils.checkpoint import checkpoint as grad_checkpoint\nimport torchvision.transforms.functional as TF\nimport torchvision.models as models\n\n\n\n# ── CONFIG ───────────────────────────────────────────────────────────────────\nclass CFG:\n    data_dir        = '/kaggle/input/datasets/mateuszbuda/lgg-mri-segmentation/kaggle_3m'\n    img_size        = 224   # Paper uses 224×224 (patch=4, window=7 → 56×56 tokens)\n    batch_size      = 8          # Swin uses more memory\n    num_epochs      = 40\n    lr              = 1e-4\n    val_split       = 0.15\n    test_split      = 0.10\n    seed            = 42\n    device          = 'cuda' if torch.cuda.is_available() else 'cpu'\n    # Deep supervision weights: paper uses geometrically decaying\n    # model returns [main, aux1, aux2] → 3 outputs, 3 weights used\n    ds_weights      = [0.5334, 0.2667, 0.1333]\n    # Gradient checkpointing inside Swin blocks (saves ~30% VRAM)\n    use_grad_ckpt   = True\n    # Best model weights (only weights, saved when val dice improves)\n    best_model_path = './best_swinunet.pth'\n    # Full training checkpoint (weights + optimizer + scheduler + history)\n    checkpoint_path = './swinunet_checkpoint.pth'\n\n\ndef set_seed(s):\n    random.seed(s); np.random.seed(s)\n    torch.manual_seed(s)\n\nset_seed(CFG.seed)\nprint(f'Device : {CFG.device}')\n","metadata":{"id":"aZeRvErb_05_","trusted":true,"execution":{"iopub.status.busy":"2026-06-24T07:06:44.450368Z","iopub.execute_input":"2026-06-24T07:06:44.451085Z","iopub.status.idle":"2026-06-24T07:06:44.936177Z","shell.execute_reply.started":"2026-06-24T07:06:44.451050Z","shell.execute_reply":"2026-06-24T07:06:44.935527Z"}},"outputs":[{"name":"stdout","text":"Device : cuda\n","output_type":"stream"}],"execution_count":3},{"cell_type":"code","source":"# ── Cell 4: Load & explore data ───────────────────────────────────────────────\ndef get_pairs(data_dir):\n    imgs = sorted(glob.glob(os.path.join(data_dir,'**','*.tif'), recursive=True))\n    imgs = [p for p in imgs if '_mask' not in p]\n    pairs = []\n    for p in imgs:\n        m = p.replace('.tif','_mask.tif')\n        if os.path.exists(m): pairs.append((p, m))\n    return pairs\n\nall_pairs = get_pairs(CFG.data_dir)\nprint(f'Total image-mask pairs : {len(all_pairs)}')\n\n# Count positives (slices that actually contain tumour)\npos = 0\nfor _, m in all_pairs:\n    if np.array(Image.open(m)).max() > 0: pos += 1\nprint(f'Slices with tumour     : {pos} ({100*pos/len(all_pairs):.1f}%)')\nprint(f'Slices without tumour  : {len(all_pairs)-pos} ({100*(len(all_pairs)-pos)/len(all_pairs):.1f}%)')\n\n# Plot class balance\nfig, ax = plt.subplots(figsize=(5,3))\nax.bar(['With Tumour','Without Tumour'], [pos, len(all_pairs)-pos],\n       color=['#e74c3c','#3498db'], edgecolor='white', linewidth=1.5)\nax.set_title('Slice-level Class Distribution', fontweight='bold')\nax.set_ylabel('Count')\nfor p in ax.patches:\n    ax.annotate(f'{int(p.get_height())}', (p.get_x()+p.get_width()/2, p.get_height()),\n                ha='center', va='bottom', fontweight='bold')\nplt.tight_layout(); plt.show()","metadata":{"id":"WnZ5pMQw_05_","trusted":true,"execution":{"iopub.status.busy":"2026-06-24T07:07:12.720734Z","iopub.execute_input":"2026-06-24T07:07:12.721855Z","iopub.status.idle":"2026-06-24T07:07:37.817815Z","shell.execute_reply.started":"2026-06-24T07:07:12.721825Z","shell.execute_reply":"2026-06-24T07:07:37.817148Z"}},"outputs":[{"name":"stdout","text":"Total image-mask pairs : 3929\nSlices with tumour     : 1373 (34.9%)\nSlices without tumour  : 2556 (65.1%)\n","output_type":"stream"},{"output_type":"display_data","data":{"text/plain":"<Figure size 500x300 with 1 Axes>","image/png":"\n"},"metadata":{}}],"execution_count":4},{"cell_type":"code","source":"# ── Cell 5: Visualise raw samples ─────────────────────────────────────────────\n# Show 5 slices WITH tumour + overlay\npositive_pairs = [(i,m) for i,m in all_pairs if np.array(Image.open(m)).max()>0]\nsamples = random.sample(positive_pairs, 5)\n\nfig, axes = plt.subplots(5, 3, figsize=(11, 17))\nfig.suptitle('Raw Data Exploration  |  MRI — Mask — Overlay', fontsize=14, fontweight='bold', y=1.01)\n\nfor row, (ip, mp) in enumerate(samples):\n    img  = np.array(Image.open(ip).convert('RGB'))\n    mask = np.array(Image.open(mp).convert('L'))\n\n    axes[row,0].imshow(img);                    axes[row,0].set_title('MRI', fontsize=9)\n    axes[row,1].imshow(mask, cmap='hot');       axes[row,1].set_title('Mask', fontsize=9)\n\n    # Overlay: blend mask in red over greyscale MRI\n    grey = np.stack([img.mean(-1)]*3, axis=-1).astype(np.uint8)\n    overlay = grey.copy()\n    overlay[mask>127] = [220, 50, 50]\n    axes[row,2].imshow(overlay);                axes[row,2].set_title('Overlay', fontsize=9)\n\n    for ax in axes[row]: ax.axis('off')\n\nplt.tight_layout(); plt.show()","metadata":{"id":"oi9Df2-x_05_","trusted":true,"execution":{"iopub.status.busy":"2026-06-24T07:07:37.819667Z","iopub.execute_input":"2026-06-24T07:07:37.819871Z","iopub.status.idle":"2026-06-24T07:07:43.397989Z","shell.execute_reply.started":"2026-06-24T07:07:37.819851Z","shell.execute_reply":"2026-06-24T07:07:43.397074Z"}},"outputs":[{"output_type":"display_data","data":{"text/plain":"<Figure size 1100x1700 with 15 Axes>","image/png":"\n"},"metadata":{}}],"execution_count":5},{"cell_type":"code","source":"# ── Cell 6: Dataset class + augmentation preview ──────────────────────────────\nclass BrainMRIDataset(Dataset):\n    def __init__(self, pairs, img_size=256, augment=False):\n        self.pairs   = pairs\n        self.size    = img_size\n        self.augment = augment\n\n    def __len__(self): return len(self.pairs)\n\n    def __getitem__(self, idx):\n        ip, mp = self.pairs[idx]\n        img  = Image.open(ip).convert('RGB').resize((self.size,self.size), Image.BILINEAR)\n        mask = Image.open(mp).convert('L').resize((self.size,self.size), Image.NEAREST)\n\n        if self.augment:\n            if random.random()>0.5: img,mask = TF.hflip(img), TF.hflip(mask)\n            if random.random()>0.5: img,mask = TF.vflip(img), TF.vflip(mask)\n            angle = random.uniform(-30,30)\n            img,mask = TF.rotate(img,angle), TF.rotate(mask,angle)\n            if random.random()>0.5:\n                img = TF.adjust_brightness(img, random.uniform(0.8,1.2))\n                img = TF.adjust_contrast(img,   random.uniform(0.8,1.2))\n\n        img  = TF.to_tensor(img)                                    # [3,H,W]\n        mask = torch.from_numpy(np.array(mask)).float()\n        mask = (mask>127).float().unsqueeze(0)                      # [1,H,W]\n        return img, mask\n\n# Preview augmentations on one positive sample\naug_ds = BrainMRIDataset(positive_pairs[:1], augment=True)\nfig, axes = plt.subplots(2, 5, figsize=(14,6))\nfig.suptitle('Augmentation Preview (same slice, 5 random draws)', fontweight='bold')\nfor col in range(5):\n    im, mk = aug_ds[0]\n    axes[0,col].imshow(im.permute(1,2,0).numpy())\n    axes[0,col].set_title(f'Aug {col+1}'); axes[0,col].axis('off')\n    axes[1,col].imshow(mk.squeeze().numpy(), cmap='hot')\n    axes[1,col].axis('off')\naxes[0,0].set_ylabel('Image', fontweight='bold')\naxes[1,0].set_ylabel('Mask',  fontweight='bold')\nplt.tight_layout(); plt.show()","metadata":{"id":"hrJ6kJTN_06A","trusted":true,"execution":{"iopub.status.busy":"2026-06-24T07:07:59.937073Z","iopub.execute_input":"2026-06-24T07:07:59.937702Z","iopub.status.idle":"2026-06-24T07:08:00.643537Z","shell.execute_reply.started":"2026-06-24T07:07:59.937671Z","shell.execute_reply":"2026-06-24T07:08:00.642584Z"}},"outputs":[{"output_type":"display_data","data":{"text/plain":"<Figure size 1400x600 with 10 Axes>","image/png":"\n"},"metadata":{}}],"execution_count":6},{"cell_type":"code","source":"# ── Cell 7: Train / Val / Test split + DataLoaders ────────────────────────────\ntrain_pairs, temp  = train_test_split(all_pairs, test_size=CFG.val_split+CFG.test_split, random_state=CFG.seed)\nval_pairs,  test_pairs = train_test_split(temp,\n    test_size=CFG.test_split/(CFG.val_split+CFG.test_split), random_state=CFG.seed)\n\nprint(f'Train : {len(train_pairs)} | Val : {len(val_pairs)} | Test : {len(test_pairs)}')\n\ntrain_ds = BrainMRIDataset(train_pairs, CFG.img_size, augment=True)\nval_ds   = BrainMRIDataset(val_pairs,   CFG.img_size, augment=False)\ntest_ds  = BrainMRIDataset(test_pairs,  CFG.img_size, augment=False)\n\nnw = 2\ntrain_loader = DataLoader(train_ds, CFG.batch_size, shuffle=True,  num_workers=nw, pin_memory=True)\nval_loader   = DataLoader(val_ds,   CFG.batch_size, shuffle=False, num_workers=nw, pin_memory=True)\ntest_loader  = DataLoader(test_ds,  CFG.batch_size, shuffle=False, num_workers=nw, pin_memory=True)\n\nimgs, masks = next(iter(train_loader))\nprint(f'Batch — images: {tuple(imgs.shape)}  masks: {tuple(masks.shape)}')","metadata":{"id":"GI6qkGjK_06A","trusted":true,"execution":{"iopub.status.busy":"2026-06-24T07:08:17.011322Z","iopub.execute_input":"2026-06-24T07:08:17.011960Z","iopub.status.idle":"2026-06-24T07:08:17.620224Z","shell.execute_reply.started":"2026-06-24T07:08:17.011930Z","shell.execute_reply":"2026-06-24T07:08:17.619225Z"}},"outputs":[{"name":"stdout","text":"Train : 2946 | Val : 589 | Test : 394\nBatch — images: (8, 3, 224, 224)  masks: (8, 1, 224, 224)\n","output_type":"stream"}],"execution_count":7},{"cell_type":"markdown","source":"\n\n","metadata":{}},{"cell_type":"code","source":"# ── : Swin-UNet — Paper-faithful Architecture ──────────────────────────\n#\n# Reference: Cao et al. 2021 – \"Swin-Unet: Unet-like Pure Transformer for\n#            Medical Image Segmentation\"  arXiv:2105.05537\n#\n#\n# Architecture (paper §3, Fig. 2):\n#   Patch Partition \n# -------------------------------------------------------------------------------\n#   Linear Embedding (patch=4, C=96)\n#   Encoder stage 1: 2 × Swin-Block  (W-MSA → SW-MSA)  │  C=96,  res=H/4\n# -------------------------------------------------------------------------------\n#   PatchMerging                                         │  C=192, res=H/8\n#   Encoder stage 2: 2 × Swin-Block                     │  C=192, res=H/8\n# -------------------------------------------------------------------------------\n#   PatchMerging                                         │  C=384, res=H/16\n#   Encoder stage 3: 6 × Swin-Block                     │  C=384, res=H/16\n# -------------------------------------------------------------------------------\n#   PatchMerging                                         │  C=768, res=H/32\n# -------------------------------------------------------------------------------\n#   Bottleneck:      2 × Swin-Block                     │  C=768, res=H/32\n# -------------------------------------------------------------------------------\n# -------------------------------------------------------------------------------\n#   PatchExpanding                                       │  C=384, res=H/16  + skip\n#   Decoder stage 3: 2 × Swin-Block                     │  C=384, res=H/16\n# -------------------------------------------------------------------------------\n#   PatchExpanding                                       │  C=192, res=H/8   + skip\n#   Decoder stage 2: 2 × Swin-Block                     │  C=192, res=H/8\n# -------------------------------------------------------------------------------\n#   PatchExpanding                                       │  C=96,  res=H/4   + skip\n#   Decoder stage 1: 2 × Swin-Block                     │  C=96,  res=H/4\n# -------------------------------------------------------------------------------\n#   FinalPatchExpand_X4                                  │  C=96,  res=H\n# -------------------------------------------------------------------------------\n#   Linear head                                          │  n_classes\n\nimport math\nimport torch\nimport torch.nn as nn\nimport torch.nn.functional as F\nimport torch.utils.checkpoint as checkpoint_fn\nfrom einops import rearrange\n\n","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-06-24T07:15:39.343108Z","iopub.execute_input":"2026-06-24T07:15:39.343590Z","iopub.status.idle":"2026-06-24T07:15:39.348779Z","shell.execute_reply.started":"2026-06-24T07:15:39.343560Z","shell.execute_reply":"2026-06-24T07:15:39.348040Z"}},"outputs":[],"execution_count":12},{"cell_type":"code","source":"# ─────────────────────────────────────────────────────────────────────────────\n# 8.1. PATCH PARTITION + LINEAR EMBEDDING\n# ─────────────────────────────────────────────────────────────────────────────\nclass PatchEmbed(nn.Module):\n    \"\"\"Non-overlapping patch partition then linear projection.\n    Paper §3.1: patch_size=4, embed_dim=96.\n    Output: (B, L, C)  where L = (H/patch_size) * (W/patch_size)\n    \"\"\"\n    def __init__(self, img_size=224, patch_size=4, in_chans=3, embed_dim=96,\n                 norm_layer=None):\n        super().__init__()\n        self.img_size   = (img_size, img_size)\n        self.patch_size = (patch_size, patch_size)\n        self.H_patches  = img_size // patch_size\n        self.W_patches  = img_size // patch_size\n        self.num_patches = self.H_patches * self.W_patches\n        # Paper uses a single conv for efficiency but it is purely a linear projection\n        # (no ReLU, no BN) — equivalent to the patch-flatten + linear described in paper.\n        self.proj = nn.Conv2d(in_chans, embed_dim,\n                              kernel_size=patch_size, stride=patch_size)\n        self.norm = norm_layer(embed_dim) if norm_layer else nn.Identity()\n\n    def forward(self, x):\n        B, C, H, W = x.shape\n        x = self.proj(x)                        # (B, embed_dim, H/4, W/4)\n        x = x.flatten(2).transpose(1, 2)       # (B, L, embed_dim)\n        x = self.norm(x)\n        return x, self.H_patches, self.W_patches\n\n\n# ─────────────────────────────────────────────────────────────────────────────\n# 8.2. PATCH MERGING  (encoder downsampling — paper §3.1)\n# ─────────────────────────────────────────────────────────────────────────────\nclass PatchMerging(nn.Module):\n    \"\"\"Concatenate 2×2 neighbouring patch tokens then project: C → 2C.\n    Spatial resolution halved, channels doubled.\n    Input : (B, H*W, C)  →  Output: (B, H/2*W/2, 2C)\n    \"\"\"\n    def __init__(self, input_resolution, dim, norm_layer=nn.LayerNorm):\n        super().__init__()\n        self.input_resolution = input_resolution\n        self.dim = dim\n        self.reduction = nn.Linear(4 * dim, 2 * dim, bias=False)\n        self.norm = norm_layer(4 * dim)\n\n    def forward(self, x, H, W):\n        B, L, C = x.shape\n        x = x.view(B, H, W, C)\n        x0 = x[:, 0::2, 0::2, :]  # top-left\n        x1 = x[:, 1::2, 0::2, :]  # bottom-left\n        x2 = x[:, 0::2, 1::2, :]  # top-right\n        x3 = x[:, 1::2, 1::2, :]  # bottom-right\n        x  = torch.cat([x0, x1, x2, x3], dim=-1)  # (B, H/2, W/2, 4C)\n        x  = x.view(B, -1, 4 * C)\n        x  = self.norm(x)\n        x  = self.reduction(x)                     # (B, H/2*W/2, 2C)\n        return x, H // 2, W // 2\n\n\n# ─────────────────────────────────────────────────────────────────────────────\n# 8.3. PATCH EXPANDING  (decoder upsampling — paper §3.2, the key novelty)\n# ─────────────────────────────────────────────────────────────────────────────\nclass PatchExpanding(nn.Module):\n    \"\"\"Linear(C → 2C) then rearrange to double spatial, halve channels.\n    This replaces ConvTranspose2d in the paper's pure-Transformer decoder.\n    Input : (B, H*W, C)  →  Output: (B, 2H*2W, C/2)\n    \"\"\"\n    def __init__(self, input_resolution, dim, dim_scale=2, norm_layer=nn.LayerNorm):\n        super().__init__()\n        self.input_resolution = input_resolution\n        self.dim = dim\n        self.expand = nn.Linear(dim, 2 * dim, bias=False)  # Paper-faithful: C -> 2C\n        self.norm   = norm_layer(dim // dim_scale)         # Paper-faithful: C/2\n\n    def forward(self, x, H, W):\n        x = self.expand(x)          # (B, H*W, 2C)\n        B, L, C = x.shape\n        x = x.view(B, H, W, C)\n\n        # Paper states: double spatial resolution (2H * 2W), quarter the 2C channel size\n        # p1=2 and p2=2 splits the 2C tensor into 2 * 2 * (2C / 4) which leaves exactly C/2 channels.\n        x = rearrange(x, 'b h w (p1 p2 c) -> b (h p1) (w p2) c',\n                      p1=2, p2=2, c=C // 4)\n        x = x.reshape(B, -1, self.dim // 2)\n        x = self.norm(x)\n        return x, H * 2, W * 2\n\n\nclass FinalPatchExpand_X4(nn.Module):\n    \"\"\"Final 4× upsample from H/4 back to H  (paper \"expand_first\" §3.3).\n    Input : (B, H/4*W/4, C)  →  Output: (B, H*W, C)\n    \"\"\"\n    def __init__(self, input_resolution, dim, dim_scale=4, norm_layer=nn.LayerNorm):\n        super().__init__()\n        self.input_resolution = input_resolution\n        self.dim = dim\n        self.dim_scale  = dim_scale\n        self.expand     = nn.Linear(dim, 16 * dim, bias=False)   # C → 16C\n        self.output_dim = dim\n        self.norm       = norm_layer(self.output_dim)\n\n    def forward(self, x, H, W):\n        x = self.expand(x)         # (B, H/4*W/4, 16C)\n        B, L, C = x.shape\n        x = x.view(B, H, W, C)\n        # rearrange: each token expands to 4×4 block, C stays the same\n        x = rearrange(x, 'b h w (p1 p2 c) -> b (h p1) (w p2) c',\n                      p1=self.dim_scale, p2=self.dim_scale,\n                      c=C // (self.dim_scale ** 2))\n        x = x.reshape(B, -1, self.output_dim)\n        x = self.norm(x)\n        return x, H * self.dim_scale, W * self.dim_scale\n","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-06-24T07:36:47.504861Z","iopub.execute_input":"2026-06-24T07:36:47.505763Z","iopub.status.idle":"2026-06-24T07:36:47.520811Z","shell.execute_reply.started":"2026-06-24T07:36:47.505727Z","shell.execute_reply":"2026-06-24T07:36:47.520178Z"}},"outputs":[],"execution_count":21},{"cell_type":"code","source":"# ─────────────────────────────────────────────────────────────────────────────\n# 8.4. WINDOWED SELF-ATTENTION  (W-MSA and SW-MSA — paper §3.1)\n# ─────────────────────────────────────────────────────────────────────────────\ndef window_partition(x, window_size):\n    \"\"\"x: (B, H, W, C)  →  (num_windows*B, ws, ws, C)\"\"\"\n    B, H, W, C = x.shape\n    x = x.view(B, H // window_size, window_size,\n                   W // window_size, window_size, C)\n    windows = x.permute(0, 1, 3, 2, 4, 5).contiguous()\n    return windows.view(-1, window_size, window_size, C)\n\n\ndef window_reverse(windows, window_size, H, W):\n    \"\"\"(num_windows*B, ws, ws, C)  →  (B, H, W, C)\"\"\"\n    B = int(windows.shape[0] / (H * W / window_size / window_size))\n    x = windows.view(B, H // window_size, W // window_size,\n                        window_size, window_size, -1)\n    return x.permute(0, 1, 3, 2, 4, 5).contiguous().view(B, H, W, -1)\n\n\nclass WindowAttention(nn.Module):\n    \"\"\"Window-based multi-head self-attention with relative position bias.\n    shift_size=0  → W-MSA; shift_size>0 handled by cyclic shift in the block.\n    \"\"\"\n    def __init__(self, dim, window_size, num_heads, qkv_bias=True,\n                 attn_drop=0., proj_drop=0.):\n        super().__init__()\n        self.dim         = dim\n        self.window_size = window_size\n        self.num_heads   = num_heads\n        head_dim         = dim // num_heads\n        self.scale       = head_dim ** -0.5\n\n        # relative position bias: (2W-1)*(2W-1) entries per head\n        self.relative_position_bias_table = nn.Parameter(\n            torch.zeros((2 * window_size - 1) * (2 * window_size - 1), num_heads))\n        nn.init.trunc_normal_(self.relative_position_bias_table, std=0.02)\n\n        coords_h = torch.arange(window_size)\n        coords_w = torch.arange(window_size)\n        coords   = torch.stack(torch.meshgrid([coords_h, coords_w], indexing='ij'))\n        coords_flat = torch.flatten(coords, 1)                     # (2, Wh*Ww)\n        rel = coords_flat[:, :, None] - coords_flat[:, None, :]    # (2, N, N)\n        rel = rel.permute(1, 2, 0).contiguous()\n        rel[:, :, 0] += window_size - 1\n        rel[:, :, 1] += window_size - 1\n        rel[:, :, 0] *= 2 * window_size - 1\n        self.register_buffer(\"relative_position_index\", rel.sum(-1))  # (N, N)\n\n        self.qkv       = nn.Linear(dim, dim * 3, bias=qkv_bias)\n        self.proj      = nn.Linear(dim, dim)\n        self.attn_drop = nn.Dropout(attn_drop)\n        self.proj_drop = nn.Dropout(proj_drop)\n\n    def forward(self, x, mask=None):\n        B_, N, C = x.shape\n        qkv = self.qkv(x).reshape(B_, N, 3, self.num_heads, C // self.num_heads)\n        q, k, v = qkv.permute(2, 0, 3, 1, 4).unbind(0)\n\n        attn = (q * self.scale) @ k.transpose(-2, -1)\n\n        rp_bias = self.relative_position_bias_table[\n            self.relative_position_index.view(-1)\n        ].view(self.window_size ** 2, self.window_size ** 2, -1)\n        attn = attn + rp_bias.permute(2, 0, 1).contiguous().unsqueeze(0)\n\n        if mask is not None:\n            nW = mask.shape[0]\n            attn = attn.view(B_ // nW, nW, self.num_heads, N, N)\n            attn = attn + mask.unsqueeze(1).unsqueeze(0)\n            attn = attn.view(-1, self.num_heads, N, N)\n\n        attn = self.attn_drop(attn.softmax(dim=-1))\n        x    = (attn @ v).transpose(1, 2).reshape(B_, N, C)\n        return self.proj_drop(self.proj(x))\n\n","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-06-24T07:36:58.573185Z","iopub.execute_input":"2026-06-24T07:36:58.573935Z","iopub.status.idle":"2026-06-24T07:36:58.586770Z","shell.execute_reply.started":"2026-06-24T07:36:58.573902Z","shell.execute_reply":"2026-06-24T07:36:58.586118Z"}},"outputs":[],"execution_count":22},{"cell_type":"code","source":"# ─────────────────────────────────────────────────────────────────────────────\n# 8.5. MLP + STOCHASTIC DEPTH\n# ─────────────────────────────────────────────────────────────────────────────\nclass Mlp(nn.Module):\n    def __init__(self, in_features, hidden_features=None, out_features=None,\n                 act_layer=nn.GELU, drop=0.):\n        super().__init__()\n        hid = hidden_features or in_features\n        out = out_features    or in_features\n        self.fc1  = nn.Linear(in_features, hid)\n        self.act  = act_layer()\n        self.fc2  = nn.Linear(hid, out)\n        self.drop = nn.Dropout(drop)\n\n    def forward(self, x):\n        return self.drop(self.fc2(self.drop(self.act(self.fc1(x)))))\n\n\nclass DropPath(nn.Module):\n    def __init__(self, drop_prob=0.):\n        super().__init__()\n        self.drop_prob = drop_prob\n\n    def forward(self, x):\n        if self.drop_prob == 0. or not self.training:\n            return x\n        keep  = 1 - self.drop_prob\n        shape = (x.shape[0],) + (1,) * (x.ndim - 1)\n        rand  = torch.rand(shape, dtype=x.dtype, device=x.device)\n        return x * torch.floor(rand + keep) / keep\n","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-06-24T07:37:02.663225Z","iopub.execute_input":"2026-06-24T07:37:02.663845Z","iopub.status.idle":"2026-06-24T07:37:02.671130Z","shell.execute_reply.started":"2026-06-24T07:37:02.663813Z","shell.execute_reply":"2026-06-24T07:37:02.670352Z"}},"outputs":[],"execution_count":23},{"cell_type":"code","source":"# ─────────────────────────────────────────────────────────────────────────────\n# 8.6. SWIN TRANSFORMER BLOCK  (alternates W-MSA / SW-MSA)\n# ─────────────────────────────────────────────────────────────────────────────\nclass SwinTransformerBlock(nn.Module):\n    \"\"\"Paper eq.(3)–(4):\n    z̃^l = W-MSA(LN(z^{l-1})) + z^{l-1}\n    z^l  = MLP(LN(z̃^l)) + z̃^l\n    (SW-MSA for odd-indexed blocks in each stage)\n    \"\"\"\n    def __init__(self, dim, input_resolution, num_heads, window_size=7,\n                 shift_size=0, mlp_ratio=4., qkv_bias=True, drop=0.,\n                 attn_drop=0., drop_path=0., norm_layer=nn.LayerNorm):\n        super().__init__()\n        self.shift_size = shift_size\n        self.window_size = window_size\n        if min(input_resolution) <= window_size:\n            self.shift_size  = 0\n            self.window_size = min(input_resolution)\n\n        self.norm1    = norm_layer(dim)\n        self.attn     = WindowAttention(dim, self.window_size, num_heads,\n                                        qkv_bias, attn_drop, drop)\n        self.drop_path = DropPath(drop_path) if drop_path > 0. else nn.Identity()\n        self.norm2    = norm_layer(dim)\n        self.mlp      = Mlp(dim, int(dim * mlp_ratio), drop=drop)\n\n        # cyclic-shift attention mask (computed once, stored as buffer)\n        if self.shift_size > 0:\n            H, W = input_resolution\n            img_mask = torch.zeros(1, H, W, 1)\n            for h in (slice(0, -self.window_size),\n                      slice(-self.window_size, -self.shift_size),\n                      slice(-self.shift_size, None)):\n                for w in (slice(0, -self.window_size),\n                          slice(-self.window_size, -self.shift_size),\n                          slice(-self.shift_size, None)):\n                    img_mask[:, h, w, :] = torch.randint(0, 9, (1,)).float()\n            # rebuild properly\n            img_mask = torch.zeros(1, H, W, 1)\n            cnt = 0\n            for h in (slice(0, -self.window_size),\n                      slice(-self.window_size, -self.shift_size),\n                      slice(-self.shift_size, None)):\n                for w in (slice(0, -self.window_size),\n                          slice(-self.window_size, -self.shift_size),\n                          slice(-self.shift_size, None)):\n                    img_mask[:, h, w, :] = cnt\n                    cnt += 1\n            mw = window_partition(img_mask, self.window_size)\n            mw = mw.view(-1, self.window_size * self.window_size)\n            attn_mask = mw.unsqueeze(1) - mw.unsqueeze(2)\n            attn_mask = attn_mask.masked_fill(attn_mask != 0, float(-100.0)) \\\n                                 .masked_fill(attn_mask == 0, float(0.0))\n        else:\n            attn_mask = None\n        self.register_buffer(\"attn_mask\", attn_mask)\n\n    def forward(self, x, H, W):\n        B, L, C = x.shape\n        shortcut = x\n        x = self.norm1(x).view(B, H, W, C)\n\n        if self.shift_size > 0:\n            x = torch.roll(x, shifts=(-self.shift_size, -self.shift_size), dims=(1, 2))\n\n        x_w = window_partition(x, self.window_size)\n        x_w = x_w.view(-1, self.window_size * self.window_size, C)\n        x_w = self.attn(x_w, mask=self.attn_mask)\n        x_w = x_w.view(-1, self.window_size, self.window_size, C)\n        x   = window_reverse(x_w, self.window_size, H, W)\n\n        if self.shift_size > 0:\n            x = torch.roll(x, shifts=(self.shift_size, self.shift_size), dims=(1, 2))\n\n        x = x.view(B, H * W, C)\n        x = shortcut + self.drop_path(x)\n        x = x + self.drop_path(self.mlp(self.norm2(x)))\n        return x\n\n","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-06-24T07:37:07.519663Z","iopub.execute_input":"2026-06-24T07:37:07.520246Z","iopub.status.idle":"2026-06-24T07:37:07.533103Z","shell.execute_reply.started":"2026-06-24T07:37:07.520214Z","shell.execute_reply":"2026-06-24T07:37:07.532387Z"}},"outputs":[],"execution_count":24},{"cell_type":"code","source":"# ─────────────────────────────────────────────────────────────────────────────\n# 8.7. BASIC LAYER  (encoder stage)\n# ─────────────────────────────────────────────────────────────────────────────\nclass BasicLayer(nn.Module):\n    \"\"\"Stack of Swin blocks (alternating W-MSA / SW-MSA) + optional PatchMerging.\"\"\"\n    def __init__(self, dim, input_resolution, depth, num_heads, window_size,\n                 mlp_ratio=4., qkv_bias=True, drop=0., attn_drop=0.,\n                 drop_path=0., norm_layer=nn.LayerNorm, downsample=None,\n                 use_checkpoint=False):\n        super().__init__()\n        self.use_checkpoint = use_checkpoint\n        self.blocks = nn.ModuleList([\n            SwinTransformerBlock(\n                dim=dim, input_resolution=input_resolution,\n                num_heads=num_heads, window_size=window_size,\n                shift_size=0 if (i % 2 == 0) else window_size // 2,\n                mlp_ratio=mlp_ratio, qkv_bias=qkv_bias,\n                drop=drop, attn_drop=attn_drop,\n                drop_path=drop_path[i] if isinstance(drop_path, list) else drop_path,\n                norm_layer=norm_layer)\n            for i in range(depth)\n        ])\n        self.downsample = downsample\n\n    def forward(self, x, H, W):\n        for blk in self.blocks:\n            if self.use_checkpoint:\n                x = checkpoint_fn.checkpoint(blk, x, H, W, use_reentrant=False)\n            else:\n                x = blk(x, H, W)\n        # return pre-merge features (for skip connections) + post-merge\n        x_skip = x\n        if self.downsample is not None:\n            x, H, W = self.downsample(x, H, W)\n        return x_skip, x, H, W\n\n\n# ─────────────────────────────────────────────────────────────────────────────\n# 8.8. BASIC LAYER UP  (decoder stage)\n# ─────────────────────────────────────────────────────────────────────────────\nclass BasicLayer_up(nn.Module):\n    \"\"\"PatchExpanding → concat skip → Linear norm → Swin blocks.\"\"\"\n    def __init__(self, dim, input_resolution, depth, num_heads, window_size,\n                 mlp_ratio=4., qkv_bias=True, drop=0., attn_drop=0.,\n                 drop_path=0., norm_layer=nn.LayerNorm, upsample=None,\n                 use_checkpoint=False):\n        super().__init__()\n        self.upsample        = upsample\n        self.use_checkpoint  = use_checkpoint\n        # After PatchExpanding (C/2) concat with skip (C/2) → C, then project to C/2\n        self.concat_linear   = nn.Linear(dim * 2, dim) if upsample is not None else nn.Identity()\n        self.norm_after_cat  = norm_layer(dim)         if upsample is not None else nn.Identity()\n        self.blocks = nn.ModuleList([\n            SwinTransformerBlock(\n                dim=dim, input_resolution=input_resolution,\n                num_heads=num_heads, window_size=window_size,\n                shift_size=0 if (i % 2 == 0) else window_size // 2,\n                mlp_ratio=mlp_ratio, qkv_bias=qkv_bias,\n                drop=drop, attn_drop=attn_drop,\n                drop_path=drop_path[i] if isinstance(drop_path, list) else drop_path,\n                norm_layer=norm_layer)\n            for i in range(depth)\n        ])\n\n    def forward(self, x, skip, H, W):\n        if self.upsample is not None:\n            x, H, W = self.upsample(x, H, W)           # (B, 4L, C/2)\n            x = torch.cat([x, skip], dim=-1)            # (B, 4L, C)  concat skip\n            x = self.norm_after_cat(self.concat_linear(x))  # (B, 4L, C/2)\n        for blk in self.blocks:\n            if self.use_checkpoint:\n                x = checkpoint_fn.checkpoint(blk, x, H, W, use_reentrant=False)\n            else:\n                x = blk(x, H, W)\n        return x, H, W\n","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-06-24T07:37:12.885754Z","iopub.execute_input":"2026-06-24T07:37:12.886494Z","iopub.status.idle":"2026-06-24T07:37:12.897412Z","shell.execute_reply.started":"2026-06-24T07:37:12.886462Z","shell.execute_reply":"2026-06-24T07:37:12.896635Z"}},"outputs":[],"execution_count":25},{"cell_type":"code","source":"# ─────────────────────────────────────────────────────────────────────────────\n# 8.9. SWIN-UNET  (paper-faithful, pure Transformer)\n# ─────────────────────────────────────────────────────────────────────────────\nclass SwinUNet(nn.Module):\n    \"\"\"\n    Swin-UNet: Unet-like Pure Transformer (Cao et al. 2021, arXiv:2105.05537).\n\n    ZERO convolutional layers.  No pretrained backbone required.\n    Swin-Tiny config:\n        embed_dim=96, depths=[2,2,6,2], num_heads=[3,6,12,24], window_size=7\n\n    Input : (B, 3, 224, 224)\n    Eval  : (B, n_classes, 224, 224)\n    Train : [(B, n_classes, 224, 224), aux1, aux2]  for deep supervision\n    \"\"\"\n    def __init__(\n        self,\n        img_size=224, patch_size=4, in_chans=3, n_classes=1,\n        embed_dim=96,\n        depths=[2, 2, 6, 2],\n        depths_decoder=[2, 2, 2, 2],\n        num_heads=[3, 6, 12, 24],\n        window_size=7,\n        mlp_ratio=4.,\n        qkv_bias=True,\n        drop_rate=0.,\n        attn_drop_rate=0.,\n        drop_path_rate=0.1,\n        norm_layer=nn.LayerNorm,\n        ape=False,\n        patch_norm=True,\n        use_checkpoint=False,\n        final_upsample=\"expand_first\",\n    ):\n        super().__init__()\n        self.n_classes      = n_classes\n        self.num_layers     = len(depths)\n        self.embed_dim      = embed_dim\n        self.ape            = ape\n        self.num_features   = int(embed_dim * 2 ** (self.num_layers - 1))  # 768\n        self.final_upsample = final_upsample\n\n        # ── Patch Partition + Linear Embedding ──────────────────────────────\n        self.patch_embed = PatchEmbed(\n            img_size=img_size, patch_size=patch_size, in_chans=in_chans,\n            embed_dim=embed_dim,\n            norm_layer=norm_layer if patch_norm else None)\n        patches_res = [self.patch_embed.H_patches, self.patch_embed.W_patches]\n\n        if ape:\n            self.absolute_pos_embed = nn.Parameter(\n                torch.zeros(1, self.patch_embed.num_patches, embed_dim))\n            nn.init.trunc_normal_(self.absolute_pos_embed, std=0.02)\n\n        self.pos_drop = nn.Dropout(p=drop_rate)\n\n        # stochastic depth schedule\n        total_blocks = sum(depths)\n        dpr = [x.item() for x in torch.linspace(0, drop_path_rate, total_blocks)]\n\n        # ── Encoder ─────────────────────────────────────────────────────────\n        self.layers = nn.ModuleList()\n        blk_idx = 0\n        for i in range(self.num_layers):\n            dim_i  = int(embed_dim * 2 ** i)\n            res_i  = (patches_res[0] // (2 ** i), patches_res[1] // (2 ** i))\n            dep_i  = depths[i]\n            dpr_i  = dpr[blk_idx : blk_idx + dep_i]\n            blk_idx += dep_i\n            # last encoder layer is the bottleneck → no PatchMerging\n            down = PatchMerging(res_i, dim_i, norm_layer) \\\n                   if i < self.num_layers - 1 else None\n            self.layers.append(BasicLayer(\n                dim=dim_i, input_resolution=res_i, depth=dep_i,\n                num_heads=num_heads[i], window_size=window_size,\n                mlp_ratio=mlp_ratio, qkv_bias=qkv_bias,\n                drop=drop_rate, attn_drop=attn_drop_rate,\n                drop_path=dpr_i, norm_layer=norm_layer,\n                downsample=down, use_checkpoint=use_checkpoint))\n\n        # ── Decoder ─────────────────────────────────────────────────────────\n        self.layers_up = nn.ModuleList()\n        for i in range(self.num_layers):\n            # decoder goes from high-dim (bottleneck) to low-dim\n            # i=0: bottleneck stage (no upsample); i=1,2,3: expanding stages\n            dim_i  = int(embed_dim * 2 ** (self.num_layers - 1 - i))\n            res_i  = (patches_res[0] // (2 ** (self.num_layers - 1 - i)),\n                      patches_res[1] // (2 ** (self.num_layers - 1 - i)))\n            dep_i  = depths_decoder[i]\n            # PatchExpanding takes current dim (which is 2*dim_i after bottleneck)\n            # and outputs dim_i; only for i>0\n            up = PatchExpanding(res_i, dim_i * 2, dim_scale=2) if i != 0 else None\n            self.layers_up.append(BasicLayer_up(\n                dim=dim_i, input_resolution=res_i, depth=dep_i,\n                num_heads=num_heads[self.num_layers - 1 - i],\n                window_size=window_size, mlp_ratio=mlp_ratio, qkv_bias=qkv_bias,\n                drop=drop_rate, attn_drop=attn_drop_rate, drop_path=0.,\n                norm_layer=norm_layer, upsample=up,\n                use_checkpoint=use_checkpoint))\n\n        self.norm    = norm_layer(self.num_features)\n        self.norm_up = norm_layer(self.embed_dim)\n\n        # ── Final 4× expand + segmentation head ─────────────────────────────\n        self.up = FinalPatchExpand_X4(\n            input_resolution=(img_size // patch_size, img_size // patch_size),\n            dim=embed_dim, dim_scale=4, norm_layer=norm_layer)\n        self.output = nn.Linear(embed_dim, n_classes, bias=False)\n\n        # ── Deep supervision heads (one per non-bottleneck decoder stage) ────\n        # stages i=1,2 (i=3 is the final stage fed into FinalExpand)\n        self.ds_heads = nn.ModuleList([\n            nn.Linear(int(embed_dim * 2 ** (self.num_layers - 1 - i)), n_classes, bias=False)\n            for i in range(1, self.num_layers - 1)\n        ])\n\n        self._init_weights()\n\n    def _init_weights(self):\n        for m in self.modules():\n            if isinstance(m, nn.Linear):\n                nn.init.trunc_normal_(m.weight, std=0.02)\n                if m.bias is not None:\n                    nn.init.zeros_(m.bias)\n            elif isinstance(m, nn.LayerNorm):\n                nn.init.ones_(m.weight)\n                nn.init.zeros_(m.bias)\n\n    def forward(self, x):\n        B, C, H_in, W_in = x.shape\n\n        # ── Encoder ─────────────────────────────────────────────────────────\n        x, H, W = self.patch_embed(x)\n        if self.ape:\n            x = x + self.absolute_pos_embed\n        x = self.pos_drop(x)\n\n        skips = []  # store pre-merge features for skip connections\n        for layer in self.layers:\n            x_skip, x, H, W = layer(x, H, W)\n            skips.append(x_skip)\n\n        x = self.norm(x)   # normalise bottleneck output\n\n        # ── Decoder ─────────────────────────────────────────────────────────\n        aux_outs = []\n        for i, layer_up in enumerate(self.layers_up):\n            if i == 0:\n                # bottleneck: no upsample, no skip\n                x, H, W = layer_up(x, None, H, W)\n            else:\n                # skip from matching encoder stage (reverse order, skip bottleneck)\n                skip = skips[self.num_layers - 1 - i]\n                x, H, W = layer_up(x, skip, H, W)\n                # collect deep supervision output for stages 1 and 2 only\n                if i < self.num_layers - 1:\n                    aux_outs.append((x, H, W))\n\n        x = self.norm_up(x)\n\n        # ── Final 4× expand + head ───────────────────────────────────────────\n        x, H_out, W_out = self.up(x, H, W)\n        x = self.output(x)  # (B, H*W, n_classes)\n        x = x.view(B, H_out, W_out, self.n_classes).permute(0, 3, 1, 2).contiguous()\n\n        if self.training:\n            aux_preds = []\n            for ds_head, (ax, aH, aW) in zip(self.ds_heads, aux_outs):\n                ap = ds_head(ax)\n                ap = ap.view(B, aH, aW, self.n_classes).permute(0, 3, 1, 2).contiguous()\n                ap = F.interpolate(ap, size=(H_in, W_in), mode='bilinear', align_corners=False)\n                aux_preds.append(ap)\n            return [x] + aux_preds   # [main, aux1, aux2]\n        return x\n\n\n","metadata":{"id":"YpEgsbkB_06A","trusted":true,"execution":{"iopub.status.busy":"2026-06-24T07:37:18.269789Z","iopub.execute_input":"2026-06-24T07:37:18.270446Z","iopub.status.idle":"2026-06-24T07:37:18.289528Z","shell.execute_reply.started":"2026-06-24T07:37:18.270413Z","shell.execute_reply":"2026-06-24T07:37:18.288664Z"}},"outputs":[],"execution_count":26},{"cell_type":"code","source":"# ── Build model ───────────────────────────────────────────────────────────────\nmodel = SwinUNet(\n    img_size        = CFG.img_size,\n    patch_size      = 4,\n    in_chans        = 3,\n    n_classes       = 1,\n    embed_dim       = 96,\n    depths          = [2, 2, 6, 2],\n    depths_decoder  = [2, 2, 2, 2],\n    num_heads       = [3, 6, 12, 24],\n    window_size     = 7,\n    mlp_ratio       = 4.,\n    drop_path_rate  = 0.1,\n    ape             = False,   # paper uses APE=False\n    patch_norm      = True,\n    use_checkpoint  = CFG.use_grad_ckpt,\n    final_upsample  = \"expand_first\",\n)\n\nif torch.cuda.device_count() > 1:\n    print(f'Wrapping model with DataParallel on {torch.cuda.device_count()} GPUs')\n    model = nn.DataParallel(model)\n\nmodel = model.to(CFG.device)\n\ntotal_params = sum(p.numel() for p in model.parameters() if p.requires_grad)\nprint(f'Swin-UNet (paper-faithful) parameters: {total_params/1e6:.2f}M')\n\nprint('  Encoder:  PatchEmbed → 3×(Swin stage + PatchMerging) → Bottleneck Swin')\nprint('  Decoder:  3×(PatchExpanding + skip-cat + Linear + Swin stage)')\nprint('  Head:     FinalPatchExpand_X4 → Linear(embed_dim → n_classes)')\n\n# Quick shape check\nwith torch.no_grad():\n    model.eval()\n    dummy = torch.zeros(2, 3, CFG.img_size, CFG.img_size).to(CFG.device)\n    out   = model(dummy)\n    print(f'Input → Output (eval): {tuple(dummy.shape)} → {tuple(out.shape)}')\n    model.train()\n    outs  = model(dummy)\n    print(f'Output shapes (train/DS): {[tuple(o.shape) for o in outs]}')\n    model.eval()\n","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-06-24T07:37:25.918833Z","iopub.execute_input":"2026-06-24T07:37:25.919783Z","iopub.status.idle":"2026-06-24T07:37:26.913405Z","shell.execute_reply.started":"2026-06-24T07:37:25.919751Z","shell.execute_reply":"2026-06-24T07:37:26.912612Z"}},"outputs":[{"name":"stdout","text":"Wrapping model with DataParallel on 2 GPUs\nSwin-UNet (paper-faithful) parameters: 48.46M\n  Encoder:  PatchEmbed → 3×(Swin stage + PatchMerging) → Bottleneck Swin\n  Decoder:  3×(PatchExpanding + skip-cat + Linear + Swin stage)\n  Head:     FinalPatchExpand_X4 → Linear(embed_dim → n_classes)\nInput → Output (eval): (2, 3, 224, 224) → (2, 1, 224, 224)\nOutput shapes (train/DS): [(2, 1, 224, 224), (2, 1, 224, 224), (2, 1, 224, 224)]\n","output_type":"stream"}],"execution_count":27},{"cell_type":"code","source":"# ── Cell 9: Loss, metrics & optimizer ────────────────────────────────────────\n\nclass DiceBCELoss(nn.Module):\n    def __init__(self, smooth=1e-6):\n        super().__init__()\n        self.bce    = nn.BCEWithLogitsLoss()\n        self.smooth = smooth\n\n    def forward(self, logits, targets):\n        bce   = self.bce(logits, targets)\n        prob  = torch.sigmoid(logits)\n        inter = (prob * targets).sum(dim=(2, 3))\n        dice  = 1 - (2*inter + self.smooth) / (\n            prob.sum(dim=(2,3)) + targets.sum(dim=(2,3)) + self.smooth)\n        return bce + dice.mean()\n\n\nclass DeepSupervisionLoss(nn.Module):\n    \"\"\"Weighted sum of DiceBCE at each DS scale.\"\"\"\n    def __init__(self, base_loss, weights):\n        super().__init__()\n        self.base   = base_loss\n        self.weights = weights   # [w_main, w_aux1, w_aux2, w_aux3]\n\n    def forward(self, preds, targets):\n        \"\"\"preds: list of logit tensors (all at H×W). Uses len(preds) weights.\"\"\"\n        total = 0.\n        for w, p in zip(self.weights, preds):\n            total = total + w * self.base(p, targets)\n        return total\n\n\ndef dice_score(logits, targets, thr=0.5, smooth=1e-6):\n    p = (torch.sigmoid(logits) > thr).float()\n    i = (p * targets).sum(dim=(2,3))\n    return ((2*i+smooth)/(p.sum(dim=(2,3))+targets.sum(dim=(2,3))+smooth)).mean().item()\n\ndef iou_score(logits, targets, thr=0.5, smooth=1e-6):\n    p = (torch.sigmoid(logits) > thr).float()\n    i = (p * targets).sum(dim=(2,3))\n    u = (p + targets - p*targets).sum(dim=(2,3))\n    return ((i+smooth)/(u+smooth)).mean().item()\n\n\nbase_criterion = DiceBCELoss()\ncriterion      = DeepSupervisionLoss(base_criterion, CFG.ds_weights)\n\n# ── Single LR group: no pretrained encoder, all params trained from scratch ──\n# (Paper trains from random init; differential LR is not used.)\noptimizer = optim.Adam(model.parameters(), lr=CFG.lr)\n\nscheduler = optim.lr_scheduler.ReduceLROnPlateau(\n    optimizer, mode='max', patience=5, factor=0.5\n)\n\nprint('Loss, metrics, optimizer ready ✓')\n","metadata":{"id":"Vms2XjMk_06B","trusted":true,"execution":{"iopub.status.busy":"2026-06-24T07:37:45.031798Z","iopub.execute_input":"2026-06-24T07:37:45.032210Z","iopub.status.idle":"2026-06-24T07:37:45.044502Z","shell.execute_reply.started":"2026-06-24T07:37:45.032182Z","shell.execute_reply":"2026-06-24T07:37:45.043689Z"}},"outputs":[{"name":"stdout","text":"Loss, metrics, optimizer ready ✓\n","output_type":"stream"}],"execution_count":28},{"cell_type":"code","source":"# ── Cell 10: Checkpoint helpers ───────────────────────────────\n\ndef save_checkpoint(epoch, model, optimizer, scheduler, history, best_dice, path):\n    \"\"\"Save full training state — resume from here later.\"\"\"\n    os.makedirs(os.path.dirname(path), exist_ok=True)\n    torch.save({\n        'epoch':      epoch,\n        'model':      model.state_dict(),\n        'optimizer':  optimizer.state_dict(),\n        'scheduler':  scheduler.state_dict(),\n        'history':    history,\n        'best_dice':  best_dice,\n    }, path)\n    print(f'  [ckpt] Checkpoint saved → {path}')\n\n\ndef load_checkpoint(path, model, optimizer, scheduler):\n    \"\"\"\n    Load a full checkpoint.\n    Returns (start_epoch, history, best_dice) so training continues\n    from exactly where it stopped.\n    \"\"\"\n    ckpt = torch.load(path, map_location=CFG.device)\n    model.load_state_dict(ckpt['model'])\n    optimizer.load_state_dict(ckpt['optimizer'])\n    scheduler.load_state_dict(ckpt['scheduler'])\n    print(f'  [ckpt] Resumed from epoch {ckpt[\"epoch\"]} '\n          f'(best val dice so far: {ckpt[\"best_dice\"]:.4f})')\n    return ckpt['epoch'], ckpt['history'], ckpt['best_dice']\n\n\n","metadata":{"id":"wB_28HMQ_06B","trusted":true,"execution":{"iopub.status.busy":"2026-06-24T07:37:49.571015Z","iopub.execute_input":"2026-06-24T07:37:49.571801Z","iopub.status.idle":"2026-06-24T07:37:49.577855Z","shell.execute_reply.started":"2026-06-24T07:37:49.571769Z","shell.execute_reply":"2026-06-24T07:37:49.576954Z"}},"outputs":[],"execution_count":29},{"cell_type":"code","source":"# ── Try to resume from checkpoint ─────────────────────────────────────────\nhistory    = {'tl':[],'vl':[],'td':[],'vd':[],'ti':[],'vi':[]}\nbest_dice  = 0.0\nstart_epoch = 1\n\nif os.path.exists(CFG.checkpoint_path):\n    print('Found existing checkpoint — resuming training...')\n    start_epoch, history, best_dice = load_checkpoint(\n        CFG.checkpoint_path, model, optimizer, scheduler\n    )\n    start_epoch += 1  # continue from next epoch\nelse:\n    print('No checkpoint found — starting fresh.')\n\n\n","metadata":{"id":"OEC1R1YAaBn8","trusted":true,"execution":{"iopub.status.busy":"2026-06-24T07:37:54.735324Z","iopub.execute_input":"2026-06-24T07:37:54.735594Z","iopub.status.idle":"2026-06-24T07:37:54.741063Z","shell.execute_reply.started":"2026-06-24T07:37:54.735573Z","shell.execute_reply":"2026-06-24T07:37:54.740362Z"}},"outputs":[{"name":"stdout","text":"No checkpoint found — starting fresh.\n","output_type":"stream"}],"execution_count":30},{"cell_type":"code","source":"# ── Epoch functions ────────────────────────────────────────────────────────\ndef train_epoch(model, loader, opt, crit, dev):\n    model.train()\n    ls, ds, iou_acc = 0., 0., 0.\n    for imgs, masks in loader:\n        imgs, masks = imgs.to(dev), masks.to(dev)\n        opt.zero_grad()\n\n        preds = model(imgs)          # list of 4 tensors (deep supervision)\n        loss  = crit(preds, masks)   # DeepSupervisionLoss\n        loss.backward()\n        opt.step()\n\n        main_logits = preds[0].detach()   # main head for metrics\n        ls      += loss.item()\n        ds      += dice_score(main_logits, masks)\n        iou_acc += iou_score(main_logits, masks)\n\n    n = len(loader)\n    return ls/n, ds/n, iou_acc/n\n\n\n@torch.no_grad()\ndef val_epoch(model, loader, crit, dev):\n    model.eval()\n    ls, ds, iou_acc = 0., 0., 0.\n    for imgs, masks in loader:\n        imgs, masks = imgs.to(dev), masks.to(dev)\n        logits = model(imgs)          # single tensor in eval mode\n        ls      += base_criterion(logits, masks).item()\n        ds      += dice_score(logits, masks)\n        iou_acc += iou_score(logits, masks)\n    n = len(loader)\n    return ls/n, ds/n, iou_acc/n\n\nprint('Epoch functions ready ✓')\n","metadata":{"id":"BDQirccRaHCC","trusted":true,"execution":{"iopub.status.busy":"2026-06-24T07:37:58.740179Z","iopub.execute_input":"2026-06-24T07:37:58.740954Z","iopub.status.idle":"2026-06-24T07:37:58.748482Z","shell.execute_reply.started":"2026-06-24T07:37:58.740922Z","shell.execute_reply":"2026-06-24T07:37:58.747616Z"}},"outputs":[{"name":"stdout","text":"Epoch functions ready ✓\n","output_type":"stream"}],"execution_count":31},{"cell_type":"code","source":"# ── Main loop ─────────────────────────────────────────────────────────────\nremaining = CFG.num_epochs - start_epoch + 1\nif remaining <= 0:\n    print(f'Already trained {CFG.num_epochs} epochs. Increase CFG.num_epochs to continue.')\nelse:\n    print(f'Training epochs {start_epoch}–{CFG.num_epochs} on {CFG.device} ...\\n')\n    print(f'{\"Epoch\":>6} {\"T-Loss\":>8} {\"V-Loss\":>8} {\"T-Dice\":>8} '\n          f'{\"V-Dice\":>8} {\"T-IoU\":>7} {\"V-IoU\":>7}')\n    print('-'*58)\n\n    for epoch in range(start_epoch, CFG.num_epochs + 1):\n        tl,td,ti = train_epoch(model, train_loader, optimizer, criterion, CFG.device)\n        vl,vd,vi = val_epoch(model, val_loader, criterion, CFG.device)\n        scheduler.step(vd)\n\n        history['tl'].append(tl); history['vl'].append(vl)\n        history['td'].append(td); history['vd'].append(vd)\n        history['ti'].append(ti); history['vi'].append(vi)\n\n        star = ''\n        if vd > best_dice:\n            best_dice = vd\n            # Save only weights for the best model\n            os.makedirs(os.path.dirname(CFG.best_model_path), exist_ok=True)\n            torch.save(model.state_dict(), CFG.best_model_path)\n            star = ' ★'\n\n        # Save full checkpoint every epoch (overwrites previous)\n        save_checkpoint(\n            epoch, model, optimizer, scheduler,\n            history, best_dice, CFG.checkpoint_path\n        )\n\n        print(f'{epoch:>6} {tl:>8.4f} {vl:>8.4f} {td:>8.4f} '\n              f'{vd:>8.4f} {ti:>7.4f} {vi:>7.4f}{star}')\n\n    print(f'\\n Training complete — Best Val Dice: {best_dice:.4f}')\n","metadata":{"id":"WN1pWwLcYQy7","trusted":true,"execution":{"iopub.status.busy":"2026-06-24T07:38:06.895007Z","iopub.execute_input":"2026-06-24T07:38:06.895753Z","iopub.status.idle":"2026-06-24T08:52:27.973515Z","shell.execute_reply.started":"2026-06-24T07:38:06.895721Z","shell.execute_reply":"2026-06-24T08:52:27.972746Z"}},"outputs":[{"name":"stdout","text":"Training epochs 1–40 on cuda ...\n\n Epoch   T-Loss   V-Loss   T-Dice   V-Dice   T-IoU   V-IoU\n----------------------------------------------------------\n  [ckpt] Checkpoint saved → ./swinunet_checkpoint.pth\n     1   0.8814   0.8983   0.5301   0.4262  0.4974  0.3873 ★\n  [ckpt] Checkpoint saved → ./swinunet_checkpoint.pth\n     2   0.7853   0.8282   0.4917   0.4145  0.4533  0.3738\n  [ckpt] Checkpoint saved → ./swinunet_checkpoint.pth\n     3   0.7621   0.8055   0.5008   0.3290  0.4620  0.2869\n  [ckpt] Checkpoint saved → ./swinunet_checkpoint.pth\n     4   0.7507   0.8055   0.4426   0.3340  0.4034  0.2922\n  [ckpt] Checkpoint saved → ./swinunet_checkpoint.pth\n     5   0.7481   0.7967   0.4761   0.4874  0.4384  0.4482 ★\n  [ckpt] Checkpoint saved → ./swinunet_checkpoint.pth\n     6   0.7389   0.7711   0.4874   0.5446  0.4498  0.5050 ★\n  [ckpt] Checkpoint saved → ./swinunet_checkpoint.pth\n     7   0.7282   0.7798   0.5085   0.4023  0.4706  0.3611\n  [ckpt] Checkpoint saved → ./s